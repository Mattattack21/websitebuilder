# ── Supabase — frontend (public, safe to expose) ─────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# ── Supabase — backend / Netlify Functions (keep secret) ─────────────────────
# Same URL as above, but without the VITE_ prefix so it's not bundled into the browser
SUPABASE_URL=https://your-project-id.supabase.co
# Service role key bypasses RLS — used by the webhook to update any user's row
# Found in: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Claude — backend only (NEVER add VITE_ prefix) ───────────────────────────
# Found in: https://console.anthropic.com
CLAUDE_API_KEY=sk-ant-api03-...

# ── Stripe — backend only ────────────────────────────────────────────────────
# Found in: Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
# Create in: Stripe Dashboard > Products > Add product > Add price ($19.99/month recurring)
STRIPE_PRICE_ID=price_...
# Create in: Stripe Dashboard > Developers > Webhooks > Add endpoint
# Endpoint URL: https://siteforge.netlify.app/.netlify/functions/webhook
# Events to listen for: checkout.session.completed, customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
