# Claude API key — get yours at https://console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-api03-...

# Supabase project URL and anon key — found in your Supabase project settings > API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Stripe publishable key — Stripe Dashboard > Developers > API Keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe Price ID for the $19.99/month plan — Stripe Dashboard > Products > your product > price ID
VITE_STRIPE_PRICE_ID=price_...

# Stripe secret key — NEVER prefix with VITE_ or it will be exposed to the browser
# Needed for the backend server (webhook verification, session creation)
# STRIPE_SECRET_KEY=sk_test_...
